{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Modules\\IdentityAccess\\": "Modules/IdentityAccess/app/",
            "Modules\\IdentityAccess\\Database\\Factories\\": "Modules/IdentityAccess/database/factories/",
            "Modules\\IdentityAccess\\Database\\Seeders\\": "Modules/IdentityAccess/database/seeders/",
            "Modules\\Programs\\": "Modules/Programs/app/",
            "Modules\\Programs\\Database\\Factories\\": "Modules/Programs/database/factories/",
            "Modules\\Programs\\Database\\Seeders\\": "Modules/Programs/database/seeders/",
            "Modules\\Content\\": "Modules/Content/app/",
            "Modules\\Content\\Database\\Factories\\": "Modules/Content/database/factories/",
            "Modules\\Content\\Database\\Seeders\\": "Modules/Content/database/seeders/",
            "Modules\\Applications\\": "Modules/Applications/app/",
            "Modules\\Applications\\Database\\Factories\\": "Modules/Applications/database/factories/",
            "Modules\\Applications\\Database\\Seeders\\": "Modules/Applications/database/seeders/",
            "Modules\\Evaluation\\": "Modules/Evaluation/app/",
            "Modules\\Evaluation\\Database\\Factories\\": "Modules/Evaluation/database/factories/",
            "Modules\\Evaluation\\Database\\Seeders\\": "Modules/Evaluation/database/seeders/",
            "Modules\\Mentorship\\": "Modules/Mentorship/app/",
            "Modules\\Mentorship\\Database\\Factories\\": "Modules/Mentorship/database/factories/",
            "Modules\\Mentorship\\Database\\Seeders\\": "Modules/Mentorship/database/seeders/",
            "Modules\\Organizations\\": "Modules/Organizations/app/",
            "Modules\\Organizations\\Database\\Factories\\": "Modules/Organizations/database/factories/",
            "Modules\\Organizations\\Database\\Seeders\\": "Modules/Organizations/database/seeders/",
            "Modules\\Reporting\\": "Modules/Reporting/app/",
            "Modules\\Reporting\\Database\\Factories\\": "Modules/Reporting/database/factories/",
            "Modules\\Reporting\\Database\\Seeders\\": "Modules/Reporting/database/seeders/",
            "Modules\\Notifications\\": "Modules/Notifications/app/",
            "Modules\\Notifications\\Database\\Factories\\": "Modules/Notifications/database/factories/",
            "Modules\\Notifications\\Database\\Seeders\\": "Modules/Notifications/database/seeders/",
            "Modules\\AuditCompliance\\": "Modules/AuditCompliance/app/",
            "Modules\\AuditCompliance\\Database\\Factories\\": "Modules/AuditCompliance/database/factories/",
            "Modules\\AuditCompliance\\Database\\Seeders\\": "Modules/AuditCompliance/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
